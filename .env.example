# Copy to .env.local for local dev (vercel dev), and set the same vars in
# Vercel → Project → Settings → Environment Variables for production.
# NEVER commit real secrets. .env* is gitignored.

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx           # test key first; swap to sk_live_ when ready
STRIPE_WEBHOOK_SECRET=whsec_xxx         # from `stripe listen` (local) or the Vercel webhook endpoint (prod)

# --- CJdropshipping ---
CJ_EMAIL=you@example.com                # your CJ account email
CJ_API_KEY=xxxxxxxx                     # CJ → Settings → API → generate API key
CJ_LOGISTIC_NAME=CJPacket Ordinary      # shipping method name CJ should use
CJ_FROM_COUNTRY=CN                      # warehouse origin country (two-letter code)
CJ_PAY_TYPE=2                           # 2 = auto-pay from CJ balance, 3 = create order only (manual pay)
CJ_SANDBOX=1                            # 1 = CJ sandbox/test orders, 0 = real orders
